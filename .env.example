# Environment configuration for Trading Robot Marketplace
# Copy this file to .env and adjust values for your deployment

# Database Configuration
DATABASE_URL=sqlite:///./trading_robots.db

# File Upload Configuration
UPLOAD_DIR=./uploads

# MT4 Terminal Configuration
MT4_TERMINAL_PATH=/opt/metatrader4/terminal64.exe
MT4_IPC_HOST=127.0.0.1
MT4_IPC_PORT=9000

# Message Queue Configuration (Redis)
MESSAGE_QUEUE_URL=redis://localhost:6379/0

# Mode Settings (set to false for production)
DOCKER_MODE=false
USE_MOCKS=true

# Risk Management Limits
MAX_ORDER_VALUE=100000
MAX_DAILY_LOSS=5000
MAX_POSITIONS=10
MAX_ACCOUNT_RISK=0.02
MIN_ACCOUNT_BALANCE=1000

# Rate Limits
RATE_LIMITS_GENERAL_REQUESTS=100
RATE_LIMITS_GENERAL_WINDOW=60

# Webhook Configuration
WEBHOOKS_ENABLED=true
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=1.0

# Monitoring Configuration
MONITORING_CHECK_INTERVAL=1.0
MONITORING_HEARTBEAT_INTERVAL=30.0
MONITORING_MAX_HISTORY=1000

# Security
HMAC_SECRET=your-secret-key-change-in-production
JWT_SECRET=your-jwt-secret-change-in-production

# Database Pool Settings
DATABASE_POOL_SIZE=10
DATABASE_POOL_RECYCLE=3600

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/trading_robot.log

# Optional: External API Endpoints for broker integration
# BROKER_API_BASE_URL=https://api.your-broker.com
# MT4_BRIDGE_URL=https://mt4-bridge.your-server.com